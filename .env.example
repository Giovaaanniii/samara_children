# PostgreSQL (async): postgresql+asyncpg://user:password@host:5432/dbname
# Локально: localhost. В Docker Compose сервисы backend/redis переопределяют URL сами.
DATABASE_URL=postgresql+asyncpg://samara:samara@localhost:5432/samara_children

REDIS_URL=redis://localhost:6379/0

# Для docker-compose (опционально, иначе используются значения по умолчанию)
# POSTGRES_USER=samara
# POSTGRES_PASSWORD=samara
# POSTGRES_DB=samara_children

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернётся пользователь после оплаты (redirect ЮKassa)
PAYMENT_RETURN_URL=http://localhost:3000/payment/return

# Отмена бронирования: не позже чем за N часов до начала сеанса
BOOKING_CANCEL_MIN_HOURS_BEFORE_EVENT=24
# Автовозврат на карту при отмене оплаченного бронирования (ЮKassa)
BOOKING_ONLINE_REFUND_ENABLED=true

# SendGrid
SENDGRID_API_KEY=

# Firebase (путь к JSON с учётными данными сервисного аккаунта)
FIREBASE_CREDENTIALS_PATH=

EMAIL_FROM=noreply@example.com

# URL фронтенда для CORS. Docker Compose: http://localhost:3000
FRONTEND_URL=http://localhost:3000
